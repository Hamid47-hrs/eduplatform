    "turbo": "^2.10.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/api/**/*.ts": [
      "eslint --fix --config apps/web/eslint.config.mjs",
      "prettier --write"
    ],
    "packages/shared/**/*.ts": [
      "prettier --write"
    ]
  },
